{
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "cookie",
          "key": "auth",
          "value": "granted"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/gate.html"
    }
  ]
}
